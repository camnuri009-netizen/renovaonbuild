rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /cms/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /visits/{day} {
      allow read: if request.auth != null;
      allow create, update: if true;
    }
    match /stats/{doc} {
      allow read: if request.auth != null;
      allow create, update: if true;
    }
  }
}
